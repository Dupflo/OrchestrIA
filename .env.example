# OrchestrIA configuration — copy to `.env.local` and adjust.
# All variables are OPTIONAL: OrchestrIA runs with sane defaults out of the box.

# Override the SQLite database path (absolute, or relative to project root).
# Default: <project>/.orchestria/orchestria.db
# ORCHESTRIA_SQLITE=.orchestria/orchestria.db

# Autostart toggles — set to 0 to disable a subsystem at boot.
# Channels (Telegram/webhook listeners):
# ORCHESTRIA_CHANNELS_AUTOSTART=1
# Routines scheduler (cron-style missions):
# ORCHESTRIA_ROUTINES_AUTOSTART=1
# Auto-record mission outputs into agent memory:
# ORCHESTRIA_MEMORY_AUTORECORD=1
# Distill rolled-over conversation archives into a compact learnings.md that
# feeds back into the agent's prompt (opt-in — spends Claude tokens):
# ORCHESTRIA_MEMORY_DISTILL=1

# Safety limits for agent spawning.
# Max agents running concurrently (rejects new spawns past this):
# ORCHESTRIA_MAX_CONCURRENT=8
# Wall-clock timeout per mission in ms (a hung mission is killed after this):
# ORCHESTRIA_MISSION_TIMEOUT_MS=1800000

# OrchestrIA drives the `claude` CLI over a pseudo-terminal. The binary must be
# on PATH. Authenticate it once with `claude login` (uses your Claude account /
# API key managed by the CLI — OrchestrIA never reads your key directly).
